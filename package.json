{
  "name": "tinycreate",
  "version": "0.1.0",
  "author": "jamesgpearce",
  "repository": "github:tinyplex/tinycreate",
  "license": "MIT",
  "description": "A flexible CLI framework for scaffolding projects with templates",
  "keywords": [
    "cli",
    "scaffolding",
    "templates",
    "generator"
  ],
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "node build.js",
    "ts": "tsc --noEmit",
    "prettier": "prettier --check .",
    "lint": "eslint .",
    "test": "npm run build && vitest run",
    "prePublishPackage": "npm run ts && npm run prettier && npm run lint && npm run test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "prompts": "^2.4.2",
    "esbuild": "^0.24.2",
    "prettier": "^3.7.4"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}